{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "get-admin-overview output",
    "$id": "http://schema.nethserver.org/grantora/get-admin-overview-output.json",
    "type": "object",
    "required": ["workspace_id", "bootstrap", "resources", "audit", "usage", "usage_summaries"],
    "properties": {
        "workspace_id": {"type": "string"},
        "bootstrap": {"type": "object"},
        "resources": {
            "type": "object",
            "required": [
                "workspaces",
                "applications",
                "users",
                "roles",
                "capabilities",
                "agents",
                "bindings",
                "secrets",
                "capability_templates"
            ],
            "properties": {
                "workspaces": {"type": "array"},
                "applications": {"type": "array"},
                "users": {"type": "array"},
                "roles": {"type": "array"},
                "capabilities": {"type": "array"},
                "agents": {"type": "array"},
                "bindings": {"type": "array"},
                "secrets": {"type": "array"},
                "capability_templates": {"type": "array"}
            }
        },
        "audit": {"type": "array"},
        "usage": {"type": "array"},
        "usage_summaries": {"type": "array"}
    }
}