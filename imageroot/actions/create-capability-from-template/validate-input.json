{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "create-capability-from-template input",
    "$id": "http://schema.nethserver.org/grantora/create-capability-from-template-input.json",
    "type": "object",
    "additionalProperties": false,
    "required": ["template_id", "application_instance_id"],
    "properties": {
        "workspace_id": {"type": "string", "minLength": 1},
        "template_id": {"type": "string", "minLength": 1, "maxLength": 255},
        "application_instance_id": {"type": "string", "minLength": 1},
        "id": {"type": "string", "minLength": 1, "maxLength": 255},
        "name": {"type": "string", "minLength": 1, "maxLength": 255},
        "version": {"type": "integer", "minimum": 1},
        "status": {"type": "string", "enum": ["active", "disabled"]}
    }
}