import json
import subprocess
import sys
from pathlib import Path

config = json.load(sys.stdin)
helper = Path(__file__).resolve().parents[2] / "bin" / "grantora-env"

subprocess.run([helper, "configure"], input=json.dumps(config), text=True, check=True)
