{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "configure-module input",
    "$id": "http://schema.nethserver.org/grantora/configure-module-input.json",
    "description": "Configure grantora runtime and public APISIX route",
    "examples": [],
    "type": "object",
    "additionalProperties": false,
    "required": ["host"],
    "properties": {
        "host": {
            "type": "string",
            "minLength": 1,
            "maxLength": 253,
              "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,61}[A-Za-z0-9])?(\\.[A-Za-z0-9](?:[A-Za-z0-9-]{0,61}[A-Za-z0-9])?)+$"
        },
        "lets_encrypt": {
            "type": "boolean"
        },
        "user_domain": {
            "type": "string"
        },
        "sync_users_enabled": {
            "type": "boolean"
        },
        "sync_users_interval_minutes": {
            "type": "integer",
            "minimum": 1,
            "maximum": 1440
        },
        "grantora_image": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/@-]*[A-Za-z0-9]$"
        },
        "grantora_version": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._+-]*$"
        },
        "metrics_enabled": {
            "type": "boolean"
        },
        "log_level": {
            "type": "string",
            "enum": ["DEBUG", "INFO", "WARNING", "ERROR", "CRITICAL"]
        },
        "runtime_rate_limit_count": {
            "type": "integer",
            "minimum": 1,
            "maximum": 1000000
        },
        "runtime_rate_limit_time_window": {
            "type": "integer",
            "minimum": 1,
            "maximum": 86400
        },
        "audit_retention_days": {
            "type": "integer",
            "minimum": 1,
            "maximum": 3650
        },
        "usage_retention_days": {
            "type": "integer",
            "minimum": 1,
            "maximum": 3650
        },
        "upstream_tls_verify": {
            "type": "boolean"
        },
        "upstream_timeout_seconds": {
            "type": "integer",
            "minimum": 1,
            "maximum": 600
        },
        "upstream_connect_timeout_seconds": {
            "type": "integer",
            "minimum": 1,
            "maximum": 120
        },
        "upstream_max_response_bytes": {
            "type": "integer",
            "minimum": 1,
            "maximum": 1073741824
        },
        "upstream_read_retry_attempts": {
            "type": "integer",
            "minimum": 0,
            "maximum": 10
        },
        "tcp_port": {
            "type": "integer",
            "minimum": 1,
            "maximum": 65535,
            "not": {"enum": [2379, 5432, 8080, 9180]}
        }
    }
}