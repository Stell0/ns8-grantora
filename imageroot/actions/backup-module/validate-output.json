    "description": "Grantora PostgreSQL logical backup summary",
    "type": "object",
    "required": ["dump_file", "size_bytes"],
    "properties": {
        "dump_file": {"type": "string"},
        "size_bytes": {"type": "integer", "minimum": 0}
    }
}