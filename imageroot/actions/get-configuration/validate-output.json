{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "get-configuration output",
    "$id": "http://schema.nethserver.org/grantora/get-configuration-output.json",
    "description": "Get grantora runtime skeleton configuration",
    "examples": [],
    "type": "object",
    "required": [
        "configured",
        "files",
        "host",
        "grantora_image",
        "grantora_version",
        "ldap_user_domain",
        "public_base_url",
        "tcp_port"
    ],
    "properties": {
        "configured": {
            "type": "boolean"
        },
        "files": {
            "type": "object",
            "additionalProperties": {
                "type": "boolean"
            }
        },
        "host": {
            "type": "string"
        },
        "grantora_image": {
            "type": "string"
        },
        "grantora_version": {
            "type": "string"
        },
        "metrics_enabled": {
            "type": "boolean"
        },
        "log_level": {
            "type": "string"
        },
        "runtime_rate_limit_count": {
            "type": "integer"
        },
        "runtime_rate_limit_time_window": {
            "type": "integer"
        },
        "audit_retention_days": {
            "type": "integer"
        },
        "usage_retention_days": {
            "type": "integer"
        },
        "upstream_tls_verify": {
            "type": "boolean"
        },
        "upstream_timeout_seconds": {
            "type": "integer"
        },
        "upstream_connect_timeout_seconds": {
            "type": "integer"
        },
        "upstream_max_response_bytes": {
            "type": "integer"
        },
        "upstream_read_retry_attempts": {
            "type": "integer"
        },
        "ldap_user_domain": {
            "type": "string"
        },
        "public_base_url": {
            "type": "string"
        },
        "tcp_port": {
            "type": "integer"
        }
    }
}