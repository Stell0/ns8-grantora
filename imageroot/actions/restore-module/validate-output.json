{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "restore-module output",
    "$id": "http://schema.nethserver.org/grantora/restore-module-output.json",
    "description": "Grantora restore summary",
    "type": "object",
    "required": ["ok", "restored_dump_file", "size_bytes", "route_restored", "user_domain", "apisix_sync", "smoke"],
    "properties": {
        "ok": {"type": "boolean"},
        "restored_dump_file": {"type": "string"},
        "size_bytes": {"type": "integer", "minimum": 0},
        "route_restored": {"type": "boolean"},
        "user_domain": {"type": "object"},
        "apisix_sync": {"type": "object"},
        "smoke": {"type": "object"}
    }
}