#!/bin/bash

set -euo pipefail

state_dir="${STATE_DIRECTORY:-${HOME}/.local/state}/state"
backup_dir="${state_dir}/backups"
dump_file="${1:-${backup_dir}/grantora-postgres.dump}"

if [[ ! -s "${dump_file}" ]]; then
	echo "PostgreSQL dump file is missing or empty: ${dump_file}" >&2
	exit 1
fi

if ! podman container exists grantora-postgres; then
	echo "grantora-postgres container is not available" >&2
	exit 1
fi

podman cp "${dump_file}" grantora-postgres:/tmp/grantora-postgres.dump

podman exec grantora-postgres dropdb --username=grantora --if-exists grantora
podman exec grantora-postgres createdb --username=grantora grantora
podman exec grantora-postgres pg_restore \
	--username=grantora \
	--dbname=grantora \
	--clean \
	--if-exists \
	--no-owner \
	--no-acl \
	/tmp/grantora-postgres.dump
podman exec grantora-postgres rm -f /tmp/grantora-postgres.dump >/dev/null

python3 - "${dump_file}" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
print(json.dumps({"restored_dump_file": str(path), "size_bytes": path.stat().st_size}))
PY