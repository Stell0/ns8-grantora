#!/usr/bin/env python3

import argparse
import json
import os
import re
import subprocess
import sys
from pathlib import Path


STATE_DIR = Path(os.environ.get("STATE_DIRECTORY", Path.home() / ".local/state")) / "state"
REDACT_PATTERNS = (
    re.compile(r"(Bearer\s+)[A-Za-z0-9._~+/=-]+", re.IGNORECASE),
    re.compile(r'("[^"\\]*(?:token|password|secret|key)[^"\\]*"\s*:\s*")([^"\\]*)', re.IGNORECASE),
    re.compile(r"\b([A-Z0-9_]*(?:TOKEN|PASSWORD|SECRET|KEY)[A-Z0-9_]*=)([^\s]+)", re.IGNORECASE),
)


def parse_envfile(path: Path) -> dict[str, str]:
    values: dict[str, str] = {}
    if not path.exists():
        return values
    for raw_line in path.read_text(encoding="utf-8").splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, value = line.split("=", 1)
        values[key] = value
    return values


def payload_from_args(args: argparse.Namespace) -> object | None:
    if args.data is not None and args.data_json is not None:
        raise SystemExit("provide either positional data or --data-json, not both")
    raw_payload = args.data_json if args.data_json is not None else args.data
    if raw_payload is None:
        return None
    if raw_payload == "@-":
        raw_payload = sys.stdin.read()
    elif raw_payload.startswith("@"):
        raw_payload = Path(raw_payload[1:]).read_text(encoding="utf-8")
    return json.loads(raw_payload)


def redact(value: str) -> str:
    redacted = value
    for pattern in REDACT_PATTERNS:
        redacted = pattern.sub(lambda match: f"{match.group(1)}<redacted>", redacted)
    return redacted


def main() -> None:
    parser = argparse.ArgumentParser(description="Call Grantora Admin API inside the pod")
    parser.add_argument("method", nargs="?", default="GET")
    parser.add_argument("path", nargs="?", default="/v1/admin/apisix/status")
    parser.add_argument("data", nargs="?", default=None)
    parser.add_argument(
        "--data-json",
        default=None,
        help="JSON request body, @file path, or @- to read JSON from stdin",
    )
    args = parser.parse_args()

    secrets_env = parse_envfile(STATE_DIR / "secrets.env")
    token = secrets_env.get("ADMIN_BOOTSTRAP_TOKEN")
    if not token:
        print("grantora is not configured: missing ADMIN_BOOTSTRAP_TOKEN", file=sys.stderr)
        sys.exit(1)

    path = args.path if args.path.startswith("/") else f"/{args.path}"
    request = {
        "method": args.method.upper(),
        "path": path,
        "data": payload_from_args(args),
        "token": token,
    }
    script = r'''
import json
import sys
import urllib.error
import urllib.request

request = json.load(sys.stdin)
body = None
headers = {"Authorization": "Bearer " + request["token"]}
if request["data"] is not None:
    body = json.dumps(request["data"]).encode("utf-8")
    headers["Content-Type"] = "application/json"
url = "http://127.0.0.1:8080" + request["path"]
api_request = urllib.request.Request(url, data=body, headers=headers, method=request["method"])
try:
    with urllib.request.urlopen(api_request, timeout=10) as response:
        sys.stdout.buffer.write(response.read())
except urllib.error.HTTPError as exc:
    sys.stderr.buffer.write(exc.read())
    sys.exit(exc.code if exc.code < 128 else 1)
'''
    result = subprocess.run(
        ["podman", "exec", "-i", "grantora-api", "python", "-c", script],
        input=json.dumps(request),
        text=True,
        capture_output=True,
        check=False,
    )
    if result.stdout:
        sys.stdout.write(result.stdout)
    if result.stderr:
        sys.stderr.write(redact(result.stderr))
    if result.returncode != 0:
        sys.exit(result.returncode)


if __name__ == "__main__":
    main()