#!/usr/bin/env python3

import json
import os
import subprocess
import sys
from pathlib import Path


HELPER = Path(__file__).resolve().parent / "grantora-env"
ADMIN_HELPER = Path(__file__).resolve().parent / "grantora-admin"
USERS_HELPER = Path(__file__).resolve().parent / "grantora-users"
BOOTSTRAP_HELPER = Path(__file__).resolve().parent / "grantora-bootstrap"
STATE_DIR = Path(os.environ.get("STATE_DIRECTORY", Path.home() / ".local/state")) / "state"
UNITS = [
    "grantora.service",
    "grantora-pod.service",
    "grantora-postgres.service",
    "grantora-apisix-etcd.service",
    "grantora-api.service",
    "grantora-apisix.service",
    "grantora-user-sync.timer",
    "grantora-user-sync.service",
]


def command(args: list[str], stdin: str | None = None) -> subprocess.CompletedProcess[str]:
    try:
        return subprocess.run(
            args,
            input=stdin,
            text=True,
            capture_output=True,
            timeout=10,
            check=False,
        )
    except FileNotFoundError as exc:
        return subprocess.CompletedProcess(args, 127, "", str(exc))
    except subprocess.TimeoutExpired as exc:
        return subprocess.CompletedProcess(args, 124, exc.stdout or "", exc.stderr or "timeout")


def unit_state(unit: str) -> str:
    result = command(["systemctl", "--user", "is-active", unit])
    return result.stdout.strip() or "unknown"


def pod_state() -> str:
    result = command(["podman", "pod", "inspect", "grantora", "--format", "{{.State}}"])
    if result.returncode == 0:
        return result.stdout.strip() or "unknown"
    return "not_found"


def container_state(container: str) -> dict[str, object]:
    result = command(["podman", "inspect", container])
    if result.returncode != 0:
        return {"exists": False, "state": "not_found", "health": "unknown", "image": ""}
    try:
        data = json.loads(result.stdout)[0]
    except (json.JSONDecodeError, IndexError):
        return {"exists": False, "state": "unknown", "health": "unknown", "image": ""}
    state = data.get("State", {})
    config = data.get("Config", {})
    return {
        "exists": True,
        "state": state.get("Status", "unknown"),
        "health": state.get("Health", {}).get("Status", "unknown"),
        "image": config.get("Image", ""),
    }


def api_get(path: str) -> dict[str, object]:
    script = f'''
import json
import sys
import urllib.error
import urllib.request

try:
    with urllib.request.urlopen("http://127.0.0.1:8080{path}", timeout=5) as response:
        payload = response.read().decode("utf-8")
        try:
            body = json.loads(payload)
        except json.JSONDecodeError:
            body = payload
        json.dump({{"ok": True, "status_code": response.status, "body": body}}, sys.stdout)
except Exception as exc:
    json.dump({{"ok": False, "error": str(exc)}}, sys.stdout)
'''
    result = command(["podman", "exec", "grantora-api", "python", "-c", script])
    if result.returncode == 0 and result.stdout:
        return json.loads(result.stdout)
    return {"ok": False, "error": result.stderr.strip() or "not_available"}


def admin_get(path: str) -> dict[str, object]:
    if not (STATE_DIR / "secrets.env").exists():
        return {"ok": False, "error": "not_configured"}
    result = command([ADMIN_HELPER, "GET", path])
    if result.returncode != 0:
        return {"ok": False, "error": result.stderr.strip() or "not_available"}
    try:
        return {"ok": True, "body": json.loads(result.stdout or "{}")}
    except json.JSONDecodeError:
        return {"ok": True, "body": result.stdout}


def user_sync_status() -> dict[str, object]:
    result = command([USERS_HELPER, "status"])
    if result.returncode != 0:
        return {"error": result.stderr.strip() or "not_available"}
    try:
        return json.loads(result.stdout or "{}")
    except json.JSONDecodeError:
        return {"error": "invalid_status"}


def bootstrap_status() -> dict[str, object]:
    result = command([BOOTSTRAP_HELPER, "status"])
    if result.returncode != 0:
        return {"error": result.stderr.strip() or "not_available"}
    try:
        return json.loads(result.stdout or "{}")
    except json.JSONDecodeError:
        return {"error": "invalid_status"}


def main() -> None:
    env_result = subprocess.run([HELPER, "status"], text=True, check=True, capture_output=True)
    config = json.loads(env_result.stdout)
    containers = {
        "postgres": container_state("grantora-postgres"),
        "apisix_etcd": container_state("grantora-apisix-etcd"),
        "api": container_state("grantora-api"),
        "apisix": container_state("grantora-apisix"),
    }
    output = {
        "configured": config["configured"],
        "public_base_url": config["public_base_url"],
        "selected_user_domain": config.get("ldap_user_domain", ""),
        "sync_users_enabled": config.get("sync_users_enabled", False),
        "grantora_version": config["grantora_version"],
        "pod": {"name": "grantora", "state": pod_state()},
        "units": {unit: unit_state(unit) for unit in UNITS},
        "containers": containers,
        "healthz": api_get("/healthz"),
        "readyz": api_get("/readyz"),
        "apisix_sync": admin_get("/v1/admin/apisix/status"),
        "user_sync": user_sync_status(),
        "bootstrap": bootstrap_status(),
    }
    health_body = output["healthz"].get("body")
    if isinstance(health_body, dict) and health_body.get("version"):
        output["running_upstream_version"] = health_body["version"]
    else:
        output["running_upstream_version"] = ""
    json.dump(output, sys.stdout)


if __name__ == "__main__":
    main()