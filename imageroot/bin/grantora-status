#!/usr/bin/env python3

import json
import os
import re
import subprocess
import sys
from pathlib import Path
from typing import Optional


HELPER = Path(__file__).resolve().parent / "grantora-env"
ADMIN_HELPER = Path(__file__).resolve().parent / "grantora-admin"
USERS_HELPER = Path(__file__).resolve().parent / "grantora-users"
BOOTSTRAP_HELPER = Path(__file__).resolve().parent / "grantora-bootstrap"
STATE_DIR = Path(os.environ.get("STATE_DIRECTORY", Path.home() / ".local/state")) / "state"
UNITS = [
    "grantora.service",
    "grantora-pod.service",
    "grantora-postgres.service",
    "grantora-apisix-etcd.service",
    "grantora-api.service",
    "grantora-apisix.service",
    "grantora-user-sync.timer",
    "grantora-user-sync.service",
    "grantora-retention.timer",
    "grantora-retention.service",
]
CONTAINER_LABELS = (
    "org.opencontainers.image.version",
    "org.label-schema.version",
    "version",
)
REDACT_PATTERNS = (
    re.compile(r"(Bearer\s+)[A-Za-z0-9._~+/=-]+", re.IGNORECASE),
    re.compile(r'("[^"\\]*(?:token|password|secret|key)[^"\\]*"\s*:\s*")([^"\\]*)', re.IGNORECASE),
    re.compile(r"\b([A-Z0-9_]*(?:TOKEN|PASSWORD|SECRET|KEY)[A-Z0-9_]*=)([^\s]+)", re.IGNORECASE),
)


def command(args: list[str], stdin: Optional[str] = None) -> subprocess.CompletedProcess[str]:
    try:
        return subprocess.run(
            args,
            input=stdin,
            text=True,
            capture_output=True,
            timeout=10,
            check=False,
        )
    except FileNotFoundError as exc:
        return subprocess.CompletedProcess(args, 127, "", str(exc))
    except subprocess.TimeoutExpired as exc:
        return subprocess.CompletedProcess(args, 124, exc.stdout or "", exc.stderr or "timeout")


def redact(value: str) -> str:
    redacted = value
    for pattern in REDACT_PATTERNS:
        redacted = pattern.sub(lambda match: f"{match.group(1)}<redacted>", redacted)
    return redacted


def command_error(result: subprocess.CompletedProcess[str], fallback: str) -> str:
    return redact(result.stderr.strip() or result.stdout.strip() or fallback)


def load_json(path: Path) -> dict[str, object]:
    if not path.exists():
        return {}
    try:
        value = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError:
        return {}
    return value if isinstance(value, dict) else {}


def unit_state(unit: str) -> str:
    result = command(["systemctl", "--user", "is-active", unit])
    return result.stdout.strip() or "unknown"


def pod_state() -> str:
    result = command(["podman", "pod", "inspect", "grantora", "--format", "{{.State}}"])
    if result.returncode == 0:
        return result.stdout.strip() or "unknown"
    return "not_found"


def image_version(image: str) -> str:
    if "@" in image:
        return image.rsplit("@", 1)[1]
    tail = image.rsplit("/", 1)[-1]
    if ":" in tail:
        return tail.rsplit(":", 1)[1]
    return ""


def container_state(container: str) -> dict[str, object]:
    result = command(["podman", "inspect", container])
    if result.returncode != 0:
        return {
            "exists": False,
            "state": "not_found",
            "health": "unknown",
            "image": "",
            "image_id": "",
            "image_digest": "",
            "version": "",
        }
    try:
        data = json.loads(result.stdout)[0]
    except (json.JSONDecodeError, IndexError):
        return {
            "exists": False,
            "state": "unknown",
            "health": "unknown",
            "image": "",
            "image_id": "",
            "image_digest": "",
            "version": "",
        }
    state = data.get("State", {})
    config = data.get("Config", {})
    labels = config.get("Labels") or {}
    image = config.get("Image", "")
    label_version = next((str(labels[label]) for label in CONTAINER_LABELS if labels.get(label)), "")
    return {
        "exists": True,
        "state": state.get("Status", "unknown"),
        "health": state.get("Health", {}).get("Status", "unknown"),
        "image": image,
        "image_id": data.get("Image", ""),
        "image_digest": data.get("ImageDigest", ""),
        "version": label_version or image_version(image),
    }


def container_versions(containers: dict[str, dict[str, object]]) -> dict[str, dict[str, object]]:
    versions = {}
    for name, data in containers.items():
        versions[name] = {
            "image": data.get("image", ""),
            "image_id": data.get("image_id", ""),
            "image_digest": data.get("image_digest", ""),
            "version": data.get("version", ""),
        }
    return versions


def api_get(path: str) -> dict[str, object]:
    script = f'''
import json
import sys
import urllib.error
import urllib.request

try:
    with urllib.request.urlopen("http://127.0.0.1:8080{path}", timeout=5) as response:
        payload = response.read().decode("utf-8")
        try:
            body = json.loads(payload)
        except json.JSONDecodeError:
            body = payload
        json.dump({{"ok": True, "status_code": response.status, "body": body}}, sys.stdout)
except Exception as exc:
    json.dump({{"ok": False, "error": str(exc)}}, sys.stdout)
'''
    result = command(["podman", "exec", "grantora-api", "python", "-c", script])
    if result.returncode == 0 and result.stdout:
        return json.loads(result.stdout)
    return {"ok": False, "error": command_error(result, "not_available")}


def api_probe(path: str) -> dict[str, object]:
    script = f'''
import json
import sys
import urllib.request

try:
    with urllib.request.urlopen("http://127.0.0.1:8080{path}", timeout=5) as response:
        response.read(1)
        json.dump({{"ok": True, "status_code": response.status}}, sys.stdout)
except Exception as exc:
    json.dump({{"ok": False, "error": str(exc)}}, sys.stdout)
'''
    result = command(["podman", "exec", "grantora-api", "python", "-c", script])
    if result.returncode == 0 and result.stdout:
        return json.loads(result.stdout)
    return {"ok": False, "error": command_error(result, "not_available")}


def admin_get(path: str) -> dict[str, object]:
    if not (STATE_DIR / "secrets.env").exists():
        return {"ok": False, "error": "not_configured"}
    result = command([ADMIN_HELPER, "GET", path])
    if result.returncode != 0:
        return {"ok": False, "error": command_error(result, "not_available")}
    try:
        return {"ok": True, "body": json.loads(result.stdout or "{}")}
    except json.JSONDecodeError:
        return {"ok": True, "body": result.stdout}


def user_sync_status() -> dict[str, object]:
    result = command([USERS_HELPER, "status"])
    if result.returncode != 0:
        return {"error": command_error(result, "not_available")}
    try:
        return json.loads(result.stdout or "{}")
    except json.JSONDecodeError:
        return {"error": "invalid_status"}


def bootstrap_status() -> dict[str, object]:
    result = command([BOOTSTRAP_HELPER, "status"])
    if result.returncode != 0:
        return {"error": command_error(result, "not_available")}
    try:
        return json.loads(result.stdout or "{}")
    except json.JSONDecodeError:
        return {"error": "invalid_status"}


def last_sync_error(user_sync: dict[str, object]) -> str:
    if user_sync.get("error"):
        return str(user_sync["error"])
    details = user_sync.get("error_details")
    if isinstance(details, list) and details:
        first = details[0]
        if isinstance(first, dict):
            return str(first.get("error") or first)
        return str(first)
    return ""


def log_sources() -> dict[str, object]:
    return {
        "backend": "systemd-user-journal",
        "structured_json": True,
        "sources": [
            {
                "unit": unit,
                "command": f"journalctl --user-unit={unit} --no-pager",
            }
            for unit in UNITS
        ],
    }


def metrics_status(enabled: bool) -> dict[str, object]:
    status = {
        "enabled": enabled,
        "private": True,
        "path": "/metrics",
        "helper_command": "grantora-pod-exec metrics",
    }
    if enabled:
        status["probe"] = api_probe("/metrics")
    return status


def retention_status(config: dict[str, object]) -> dict[str, object]:
    return {
        "audit_retention_days": config.get("audit_retention_days", 0),
        "usage_retention_days": config.get("usage_retention_days", 0),
        "timer_state": unit_state("grantora-retention.timer"),
        "service_state": unit_state("grantora-retention.service"),
        "dry_run_supported": True,
        "helper_command": "grantora-operations retention --dry-run",
        "last_run": load_json(STATE_DIR / "retention.json"),
    }


def main() -> None:
    env_result = subprocess.run([HELPER, "status"], text=True, check=True, capture_output=True)
    config = json.loads(env_result.stdout)
    containers = {
        "postgres": container_state("grantora-postgres"),
        "apisix_etcd": container_state("grantora-apisix-etcd"),
        "api": container_state("grantora-api"),
        "apisix": container_state("grantora-apisix"),
    }
    user_sync = user_sync_status()
    healthz = api_get("/healthz")
    readyz = api_get("/readyz")
    output = {
        "configured": config["configured"],
        "public_base_url": config["public_base_url"],
        "selected_user_domain": config.get("ldap_user_domain", ""),
        "sync_users_enabled": config.get("sync_users_enabled", False),
        "grantora_version": config["grantora_version"],
        "grantora_image": config["grantora_image"],
        "pod": {"name": "grantora", "state": pod_state()},
        "units": {unit: unit_state(unit) for unit in UNITS},
        "containers": containers,
        "container_versions": container_versions(containers),
        "healthz": healthz,
        "readyz": readyz,
        "api_liveness": healthz,
        "api_readiness": readyz,
        "apisix_sync": admin_get("/v1/admin/apisix/status"),
        "user_sync": user_sync,
        "last_sync_error": last_sync_error(user_sync),
        "bootstrap": bootstrap_status(),
        "upgrade": load_json(STATE_DIR / "upgrade.json"),
        "secret_rotation": load_json(STATE_DIR / "secret-rotation.json"),
        "logs": log_sources(),
        "metrics": metrics_status(bool(config.get("metrics_enabled", False))),
        "retention": retention_status(config),
    }
    health_body = output["healthz"].get("body")
    if isinstance(health_body, dict) and health_body.get("version"):
        output["running_upstream_version"] = health_body["version"]
    else:
        output["running_upstream_version"] = ""
    json.dump(output, sys.stdout)


if __name__ == "__main__":
    main()